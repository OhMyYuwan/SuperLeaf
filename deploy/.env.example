# SuperLeaf user deployment configuration.
#
# Copy this file to .env, then run the standardized one-container deployment:
#   ./superleaf up

SUPERLEAF_PROJECT_NAME=superleaf
SUPERLEAF_BIND_ADDR=127.0.0.1
SUPERLEAF_HTTP_PORT=8080

# Default binding is localhost-only. To intentionally share SuperLeaf on a
# trusted LAN, set SUPERLEAF_BIND_ADDR=0.0.0.0 and make sure registration,
# TLS, and firewall rules match your threat model.

# Backend and collab-server run as a non-root UID/GID. `./superleaf init` and
# `./superleaf up` automatically fill these with the current host user so bind
# mounted data directories remain writable.
SUPERLEAF_RUNTIME_UID=
SUPERLEAF_RUNTIME_GID=

# Runtime scratch/cache/log directory mounted into the all-in-one container.
# Keep it on a filesystem with enough free space for LaTeX temporary files.
# Example for a large data disk:
# SUPERLEAF_RUNTIME_DIR=/data2/superleaf-runtime
SUPERLEAF_RUNTIME_DIR=

# Registration is closed by default. `./superleaf init` and `./superleaf up`
# automatically fill this in .env when it is blank. Use the generated token
# when registering the first admin account.
YLW_PUBLIC_REGISTRATION=false
YLW_BOOTSTRAP_TOKEN=
YLW_PUBLIC_BASE_URL=
YLW_REGISTRATION_INVITE_TTL_DAYS=7

# Optional invitation email delivery. Leave blank to create copyable invite
# links in /admin without sending email. Use STARTTLS SMTP on port 587 by
# default.
YLW_SMTP_HOST=
YLW_SMTP_PORT=587
YLW_SMTP_USERNAME=
YLW_SMTP_PASSWORD=
YLW_SMTP_FROM=
YLW_SMTP_TLS=true

# Session cookie Secure policy. Keep `auto` for localhost or external TLS
# reverse proxies that send X-Forwarded-Proto=https. Set `true` for public
# HTTPS deployments; never set `false` on an exposed instance.
YLW_COOKIE_SECURE=auto

# Internal backend <-> collab-server secret for document snapshot reads.
# `./superleaf init` and `./superleaf up` automatically fill this in .env when
# it is blank.
YLW_COLLAB_INTERNAL_TOKEN=

# Local Trusted MCP: allow stdio command execution (npx, uvx, python) on the
# backend. Only enable this for single-user or fully trusted local deployments.
# Public or multi-user instances MUST keep this disabled.
YLW_MCP_STDIO_ENABLED=false

# Standard all-in-one release image. This is the default deployment path and
# bundles Nginx, frontend, backend, and collab-server into one container so
# restricted Podman/Docker bridge networks do not affect startup.
SUPERLEAF_IMAGE=ghcr.io/ohmyyuwan/superleaf:latest

# Advanced multi-container release images. These are only used by:
#   ./superleaf multi-up
#
# Defaults are GHCR-compatible and also match the optional local image archive
# loaded with:
#   docker load -i images/superleaf-deploy-images.tar.gz
#
# Pin these to a version tag in production, for example:
# ghcr.io/ohmyyuwan/superleaf:v0.1.0
# ghcr.io/ohmyyuwan/superleaf-backend:v0.1.0
SUPERLEAF_BACKEND_IMAGE=ghcr.io/ohmyyuwan/superleaf-backend:latest
SUPERLEAF_FRONTEND_IMAGE=ghcr.io/ohmyyuwan/superleaf-frontend:latest
SUPERLEAF_COLLAB_IMAGE=ghcr.io/ohmyyuwan/superleaf-collab:latest

# Optional built-in TLS gateway override. Put certificates at the default paths
# or point these to existing PEM files, then run:
#   docker compose --env-file .env -f compose.yml -f compose.tls.yml up -d
SUPERLEAF_TLS_HTTP_BIND_ADDR=0.0.0.0
SUPERLEAF_TLS_HTTP_PORT=80
SUPERLEAF_TLS_HTTPS_BIND_ADDR=0.0.0.0
SUPERLEAF_TLS_HTTPS_PORT=443
SUPERLEAF_TLS_CERT_FILE=./certs/fullchain.pem
SUPERLEAF_TLS_KEY_FILE=./certs/privkey.pem
