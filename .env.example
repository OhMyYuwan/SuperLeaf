# =============================================================================
# SuperLeaf Runtime Configuration
# =============================================================================
# All env vars use the YLW_ prefix. Copy this file to .env and uncomment the
# settings you need. pydantic-settings also reads .env automatically.
#
# Reference: services/backend/app/settings.py

# -- Database ------------------------------------------------------------------
# Override the default SQLite path (~/.yuwanlab/yuwanlab.db).
# YLW_DATABASE_URL=

# YLW_DATA_DIR=~/.yuwanlab

# -- CORS ----------------------------------------------------------------------
# Extra origins to allow (JSON list). Default allows localhost:5173/5174.
# YLW_CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173"]

# Regex for CORS origin matching (advanced deployments).
# YLW_CORS_ORIGIN_REGEX=

# Allow CORS from private/LAN IPs (192.168.x.x, 10.x.x.x, 172.16-31.x.x).
# Enable this when other devices on your LAN need to access SuperLeaf.
YLW_DEV_CORS_PRIVATE_ORIGINS_ENABLED=true

# -- Auth & Registration -------------------------------------------------------
# Public self-registration. Default: false (admin-created invites only).
# YLW_PUBLIC_REGISTRATION=false

# Bootstrap token for creating the first admin user (ignored after admin exists).
# YLW_BOOTSTRAP_TOKEN=

# YLW_REGISTRATION_INVITE_TTL_DAYS=7

# -- SMTP (optional, for invite emails) ----------------------------------------
# YLW_SMTP_HOST=
# YLW_SMTP_PORT=587
# YLW_SMTP_USERNAME=
# YLW_SMTP_PASSWORD=
# YLW_SMTP_FROM=
# YLW_SMTP_TLS=true

# -- Session cookies -----------------------------------------------------------
# auto | true | false. Default: auto (Secure for HTTPS requests).
# YLW_COOKIE_SECURE=auto

# -- API docs ------------------------------------------------------------------
# Expose /docs and /openapi.json. Default: false for public deployments.
# YLW_API_DOCS_ENABLED=false

# -- Collaboration server ------------------------------------------------------
# YLW_COLLAB_SERVER_URL=http://localhost:4444
# YLW_COLLAB_SNAPSHOT_INTERVAL_S=30
# YLW_COLLAB_TOKEN_LIFETIME_SECONDS=30
# YLW_COLLAB_INTERNAL_TOKEN=

# -- Skill & MCP catalogs ------------------------------------------------------
# YLW_SKILL_MARKETPLACE_URL=https://raw.githubusercontent.com/OhMyYuwan/SuperLeaf.Skills/main/marketplace.json
# YLW_MCP_CATALOG_URL=https://raw.githubusercontent.com/OhMyYuwan/SuperLeaf.MCPs/main/catalog.json

# -- MCP execution policy ------------------------------------------------------
# YLW_MCP_REMOTE_ENABLED=true
# YLW_MCP_STDIO_ENABLED=false
# YLW_MCP_INLINE_CONFIG_ENABLED=false
# YLW_MCP_REMOTE_PRIVATE_NETWORKS_ENABLED=false

# -- Provider network policy ---------------------------------------------------
# Allow provider endpoints to target localhost/private networks (Dify, Nanobot).
# YLW_PROVIDER_PRIVATE_NETWORKS_ENABLED=false

# -- Backend-native MCP server -------------------------------------------------
# Enable /mcp protocol endpoint (separate from Local Agent Host).
# YLW_MCP_SERVER_ENABLED=false
# YLW_MCP_SESSION_TTL_SECONDS=3600
# YLW_MCP_MAX_SESSIONS=256
# YLW_MCP_EVENT_TTL_SECONDS=3600
# YLW_MCP_EVENT_MAX_PER_STREAM=200

# -- NPX skill install ---------------------------------------------------------
# Allow installing Skills via npx recipes (trusted deployments only).
# YLW_SKILL_NPX_INSTALL_ENABLED=false

# -- Docker image build --------------------------------------------------------
SUPERLEAF_IMAGE=
