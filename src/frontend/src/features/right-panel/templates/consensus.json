{
  "name": "Consensus · 多轮收敛",
  "description": "两个 Agent 在 Loop 容器内并行评议，最外层的仲裁 Agent 在每轮结束后判断是否收敛。最多 3 轮。导入后需要把每个节点的 Agent 替换为真实 Agent。",
  "execution_mode": "roundtable",
  "graph": {
    "nodes": [
      {
        "id": "input",
        "type": "input",
        "label": "输入",
        "config": {
          "position": { "x": 60, "y": 200 }
        }
      },
      {
        "id": "loop",
        "type": "loop",
        "label": "讨论循环",
        "config": {
          "position": { "x": 320, "y": 120 },
          "width": 420,
          "height": 260,
          "max_rounds": 3
        }
      },
      {
        "id": "voter_a",
        "type": "agent",
        "label": "意见 A",
        "parent": "loop",
        "config": {
          "agentId": "__PICK_AGENT__",
          "position": { "x": 360, "y": 160 },
          "promptHint": "给出你的立场与核心理由（不超过 80 字）。"
        }
      },
      {
        "id": "voter_b",
        "type": "agent",
        "label": "意见 B",
        "parent": "loop",
        "config": {
          "agentId": "__PICK_AGENT__",
          "position": { "x": 360, "y": 260 },
          "promptHint": "对意见 A 做反驳或补充（不超过 80 字）。"
        }
      },
      {
        "id": "judge",
        "type": "agent",
        "label": "收敛判断",
        "config": {
          "agentId": "__PICK_AGENT__",
          "position": { "x": 800, "y": 200 },
          "promptHint": "若本轮两个意见已经基本一致，则输出 CONVERGED 与综合结论；否则输出 CONTINUE 并给出下一轮提示。"
        }
      },
      {
        "id": "output",
        "type": "output",
        "label": "输出",
        "config": {
          "position": { "x": 1060, "y": 200 }
        }
      }
    ],
    "edges": [
      { "source": "input", "target": "loop", "target_handle": "loop-in" },
      { "source": "loop", "target": "voter_a", "source_handle": "loop-enter" },
      { "source": "loop", "target": "voter_b", "source_handle": "loop-enter" },
      { "source": "voter_a", "target": "loop", "target_handle": "loop-return" },
      { "source": "voter_b", "target": "loop", "target_handle": "loop-return" },
      { "source": "loop", "target": "judge", "source_handle": "loop-out" },
      { "source": "judge", "target": "output" }
    ]
  },
  "config": {
    "max_rounds": 3,
    "stop_conditions": ["CONVERGED"],
    "merge_strategy": "concat"
  }
}
