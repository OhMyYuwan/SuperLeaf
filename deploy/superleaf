#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"
ENV_FILE="${SUPERLEAF_ENV_FILE:-$ROOT/.env}"
COMPOSE_FILE="$ROOT/compose.yml"

compose() {
  docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

ensure_env() {
  if [ ! -f "$ENV_FILE" ]; then
    cp "$ROOT/.env.example" "$ENV_FILE"
    echo "Created $ENV_FILE from .env.example"
  fi
}

ensure_dirs() {
  mkdir -p "$ROOT/data/backend" "$ROOT/data/collab" "$ROOT/backups"
}

usage() {
  cat <<'EOF'
SuperLeaf deployment helper

Usage:
  ./superleaf up
  ./superleaf down
  ./superleaf restart
  ./superleaf status
  ./superleaf logs [service]
  ./superleaf update
  ./superleaf backup
  ./superleaf restore backups/superleaf-backup-YYYYmmdd-HHMMSS.tar.gz
EOF
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  up)
    ensure_env
    ensure_dirs
    compose up -d "$@"
    ;;
  down)
    ensure_env
    compose down "$@"
    ;;
  restart)
    ensure_env
    ensure_dirs
    compose restart "$@"
    ;;
  status|ps)
    ensure_env
    compose ps "$@"
    ;;
  logs)
    ensure_env
    compose logs -f "$@"
    ;;
  update)
    ensure_env
    ensure_dirs
    compose pull
    compose up -d
    ;;
  backup)
    ensure_env
    ensure_dirs
    stamp="$(date +%Y%m%d-%H%M%S)"
    archive="$ROOT/backups/superleaf-backup-$stamp.tar.gz"
    tar -czf "$archive" -C "$ROOT" .env data
    echo "Backup written to $archive"
    ;;
  restore)
    ensure_env
    if [ $# -ne 1 ]; then
      echo "restore requires a backup archive path" >&2
      exit 2
    fi
    archive="$1"
    compose down
    rm -rf "$ROOT/data"
    tar -xzf "$archive" -C "$ROOT"
    echo "Restored $archive"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
