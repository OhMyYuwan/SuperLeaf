#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"
ENV_FILE="${SUPERLEAF_ENV_FILE:-$ROOT/.env}"
COMPOSE_FILE="$ROOT/compose.yml"
MULTI_COMPOSE_FILE="$ROOT/compose.multi.yml"
TLS_COMPOSE_FILE="$ROOT/compose.tls.yml"
GENERATED_BOOTSTRAP_TOKEN=""
GENERATED_COLLAB_INTERNAL_TOKEN=0

compose() {
  docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

compose_tls() {
  docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" -f "$TLS_COMPOSE_FILE" "$@"
}

compose_multi() {
  docker compose --env-file "$ENV_FILE" -f "$MULTI_COMPOSE_FILE" "$@"
}

stop_multi_stack_for_single() {
  compose_multi down >/dev/null 2>&1 || true
}

generate_secret() {
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex 32
    return
  fi
  if command -v od >/dev/null 2>&1 && [ -r /dev/urandom ]; then
    od -An -N32 -tx1 /dev/urandom | tr -d ' \n'
    return
  fi
  echo "Unable to generate a secure token: openssl or /dev/urandom is required" >&2
  exit 1
}

read_env_value() {
  local key="$1"
  awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, ""); print; exit }' "$ENV_FILE"
}

detect_runtime_uid() {
  local uid
  uid="$(id -u 2>/dev/null || true)"
  if [ -n "$uid" ] && [ "$uid" != "0" ]; then
    echo "$uid"
    return
  fi
  echo "10001"
}

detect_runtime_gid() {
  local gid
  gid="$(id -g 2>/dev/null || true)"
  if [ -n "$gid" ] && [ "$gid" != "0" ]; then
    echo "$gid"
    return
  fi
  echo "10001"
}

write_env_value() {
  local key="$1"
  local value="$2"
  local tmp
  tmp="$(mktemp "$ENV_FILE.tmp.XXXXXX")"
  awk -v key="$key" -v value="$value" '
    BEGIN { found = 0 }
    $0 ~ "^" key "=" {
      print key "=" value
      found = 1
      next
    }
    { print }
    END {
      if (!found) {
        print key "=" value
      }
    }
  ' "$ENV_FILE" > "$tmp"
  mv "$tmp" "$ENV_FILE"
}

ensure_env() {
  if [ ! -f "$ENV_FILE" ]; then
    cp "$ROOT/.env.example" "$ENV_FILE"
    echo "Created $ENV_FILE from .env.example"
  fi
}

ensure_secret() {
  local key="$1"
  local value
  value="$(read_env_value "$key" | tr -d '[:space:]')"
  if [ -n "$value" ]; then
    return
  fi

  value="$(generate_secret)"
  write_env_value "$key" "$value"

  if [ "$key" = "YLW_BOOTSTRAP_TOKEN" ]; then
    GENERATED_BOOTSTRAP_TOKEN="$value"
  elif [ "$key" = "YLW_COLLAB_INTERNAL_TOKEN" ]; then
    GENERATED_COLLAB_INTERNAL_TOKEN=1
  fi
}

ensure_deploy_secrets() {
  ensure_secret "YLW_BOOTSTRAP_TOKEN"
  ensure_secret "YLW_COLLAB_INTERNAL_TOKEN"
}

ensure_runtime_identity() {
  local uid
  local gid

  uid="$(read_env_value "SUPERLEAF_RUNTIME_UID" | tr -d '[:space:]')"
  if [ -z "$uid" ]; then
    uid="$(detect_runtime_uid)"
    write_env_value "SUPERLEAF_RUNTIME_UID" "$uid"
  fi

  gid="$(read_env_value "SUPERLEAF_RUNTIME_GID" | tr -d '[:space:]')"
  if [ -z "$gid" ]; then
    gid="$(detect_runtime_gid)"
    write_env_value "SUPERLEAF_RUNTIME_GID" "$gid"
  fi
}

print_generated_secret_hints() {
  if [ -n "$GENERATED_BOOTSTRAP_TOKEN" ]; then
    cat <<EOF

Generated YLW_BOOTSTRAP_TOKEN in $ENV_FILE.
Use this Bootstrap Token when registering the first admin:

  $GENERATED_BOOTSTRAP_TOKEN

Keep it private. It is not baked into any image.
EOF
  fi

  if [ "$GENERATED_COLLAB_INTERNAL_TOKEN" -eq 1 ]; then
    echo "Generated YLW_COLLAB_INTERNAL_TOKEN in $ENV_FILE for backend <-> collab-server internal auth."
  fi
}

init_env() {
  ensure_env
  ensure_runtime_identity
  ensure_deploy_secrets
  print_generated_secret_hints
}

ensure_dirs() {
  mkdir -p "$ROOT/data/backend" "$ROOT/data/collab" "$ROOT/backups"
  if [ "$(id -u 2>/dev/null || echo 1)" = "0" ] && command -v chown >/dev/null 2>&1; then
    local uid
    local gid
    uid="$(read_env_value "SUPERLEAF_RUNTIME_UID" | tr -d '[:space:]')"
    gid="$(read_env_value "SUPERLEAF_RUNTIME_GID" | tr -d '[:space:]')"
    if [ -n "$uid" ] && [ -n "$gid" ]; then
      chown -R "$uid:$gid" "$ROOT/data/backend" "$ROOT/data/collab"
    fi
  fi
}

usage() {
  cat <<'EOF'
SuperLeaf deployment helper

Usage:
  ./superleaf init
  ./superleaf up
  ./superleaf tls-up
  ./superleaf multi-up
  ./superleaf down
  ./superleaf restart
  ./superleaf status
  ./superleaf logs [service]
  ./superleaf update
  ./superleaf backup
  ./superleaf restore backups/superleaf-backup-YYYYmmdd-HHMMSS.tar.gz
EOF
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  init)
    init_env
    ensure_dirs
    echo "Deployment environment is ready: $ENV_FILE"
    ;;
  up)
    init_env
    ensure_dirs
    stop_multi_stack_for_single
    compose up -d "$@"
    ;;
  tls-up)
    init_env
    ensure_dirs
    compose_tls up -d "$@"
    ;;
  multi-up)
    init_env
    ensure_dirs
    compose_multi up -d "$@"
    ;;
  down)
    ensure_env
    compose down "$@"
    ;;
  multi-down)
    ensure_env
    compose_multi down "$@"
    ;;
  restart)
    init_env
    ensure_dirs
    compose restart "$@"
    ;;
  multi-restart)
    init_env
    ensure_dirs
    compose_multi restart "$@"
    ;;
  status|ps)
    ensure_env
    compose ps "$@"
    ;;
  multi-status|multi-ps)
    ensure_env
    compose_multi ps "$@"
    ;;
  logs)
    ensure_env
    compose logs -f "$@"
    ;;
  multi-logs)
    ensure_env
    compose_multi logs -f "$@"
    ;;
  update)
    init_env
    ensure_dirs
    stop_multi_stack_for_single
    compose pull
    compose up -d
    ;;
  backup)
    ensure_env
    ensure_dirs
    stamp="$(date +%Y%m%d-%H%M%S)"
    archive="$ROOT/backups/superleaf-backup-$stamp.tar.gz"
    tar -czf "$archive" -C "$ROOT" .env data
    echo "Backup written to $archive"
    ;;
  restore)
    ensure_env
    if [ $# -ne 1 ]; then
      echo "restore requires a backup archive path" >&2
      exit 2
    fi
    archive="$1"
    compose down
    rm -rf "$ROOT/data"
    tar -xzf "$archive" -C "$ROOT"
    echo "Restored $archive"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
